# Copy to .dev.vars (gitignored) for local testing. Login is email-only.

# ZeptoMail HTTP Email API token (= your ZeptoMail SMTP *password*, the "enczapikey").
# Workers can't do SMTP, so we use ZeptoMail's HTTP API with this token.
# Leave blank locally → magic links are returned in the API response instead of emailed.
ZEPTOMAIL_TOKEN=

# Optional: regional endpoint override, e.g. https://api.zeptomail.eu/v1.1/email
ZEPTOMAIL_URL=
